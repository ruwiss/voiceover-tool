{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voiceover Tool",
  "version": "0.1.0",
  "identifier": "com.voiceover.tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voiceover Tool",
        "width": 1280,
        "height": 640,
        "minWidth": 980,
        "minHeight": 520,
        "fullscreen": false,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
